{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArcheOS Capability",
  "type": "object",
  "required": ["id", "name", "domain", "status", "outcome", "inputs", "outputs", "dependencies", "evaluation"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "name": {"type": "string"},
    "domain": {"type": "string"},
    "status": {"enum": ["draft", "validated", "stable", "deprecated"]},
    "outcome": {"type": "string"},
    "inputs": {"type": "array", "items": {"type": "string"}},
    "outputs": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "protocols": {"type": "array", "items": {"type": "string"}},
    "skills": {"type": "array", "items": {"type": "string"}},
    "evaluation": {"type": "array", "items": {"type": "string"}},
    "source_of_truth": {"type": "array", "items": {"type": "string"}},
    "non_responsibilities": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
